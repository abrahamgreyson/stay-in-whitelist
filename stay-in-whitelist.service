# stay-in-whitelist.service
# systemd service unit for Stay in Whitelist daemon
#
# Installation:
#   1. Copy to /etc/systemd/system/stay-in-whitelist.service
#   2. Edit paths below to match your deployment
#   3. Run: sudo systemctl daemon-reload
#   4. Run: sudo systemctl enable stay-in-whitelist
#   5. Run: sudo systemctl start stay-in-whitelist

[Unit]
Description=Stay in Whitelist - Auto-update cloud security group whitelists
Documentation=https://github.com/abrahamgreyson/stay-in-whitelist
After=network-online.target
Wants=network-online.target

[Service]
Type=simple

# User and Group (uncomment and set to your user/group)
# User=yourusername
# Group=yourgroup

# Working directory - UPDATE THIS PATH
WorkingDirectory=/opt/stay-in-whitelist

# Environment PATH to use virtual environment
Environment="PATH=/opt/stay-in-whitelist/.venv/bin:/usr/local/bin:/usr/bin:/bin"

# Command to start the daemon
ExecStart=/opt/stay-in-whitelist/.venv/bin/stay-in-whitelist

# Logging is handled by Python's TimedRotatingFileHandler (stay_in_whitelist.log).
# Do NOT set StandardOutput/StandardError to the same log file — that would cause
# duplicate log entries (FileHandler writes directly; StreamHandler writes to stdout
# which systemd would then append again to the same file).
# Use journalctl to follow live output: journalctl -u stay-in-whitelist -f

# Restart behavior
Restart=on-failure
RestartSec=10s
StartLimitIntervalSec=60
StartLimitBurst=3

# Security hardening (optional, uncomment if desired)
# ProtectSystem=strict
# ProtectHome=read-only
# NoNewPrivileges=true
# PrivateTmp=true

[Install]
WantedBy=multi-user.target
